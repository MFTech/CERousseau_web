---
import Nav from './Nav.astro';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base.slice(0, -1) : base;
---
<header class="site-header">
  <a href={`${b}/`} class="logo-link" aria-label="Centro de Estudos Rousseau — página inicial">
    <img
      src={`${b}/Logo.png`}
      alt="Centro de Estudos Rousseau do Brasil"
      class="site-logo"
      width="220"
      height="64"
    />
  </a>
  <Nav base={b} />
</header>
