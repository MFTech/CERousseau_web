# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).

# ID do Google Calendar público do CER
# Obter em: Google Calendar → Configurações → Integrar calendário → "ID do calendário"
PUBLIC_CALENDAR_ID=

# ID do formulário Formspree
# Obter em: https://formspree.io → seu formulário → endpoint (parte após /f/)
PUBLIC_FORMSPREE_ID=
